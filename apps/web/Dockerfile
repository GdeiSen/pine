FROM node:22-alpine AS base

RUN corepack enable

WORKDIR /app

FROM base AS deps

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/server/package.json ./apps/server/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY packages/shared/package.json ./packages/shared/package.json

RUN pnpm install --frozen-lockfile

FROM deps AS build

ARG BACKEND_PROXY_TARGET=http://localhost:3001
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_SOCKET_URL=
ARG NEXT_PUBLIC_MEDIA_BASE_URL=
ARG NEXT_PUBLIC_STREAM_URL=/live.mp3
ARG NEXT_PUBLIC_STREAM_PROXY_TARGET=http://icecast:8000
ARG NEXT_PUBLIC_SITE_NAME=PINE
ARG NEXT_PUBLIC_AUDIO_DEBUG=
ARG NEXT_PUBLIC_APP_DEPLOYMENT_MODE=hybrid
ENV BACKEND_PROXY_TARGET=$BACKEND_PROXY_TARGET
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SOCKET_URL=$NEXT_PUBLIC_SOCKET_URL
ENV NEXT_PUBLIC_MEDIA_BASE_URL=$NEXT_PUBLIC_MEDIA_BASE_URL
ENV NEXT_PUBLIC_STREAM_URL=$NEXT_PUBLIC_STREAM_URL
ENV NEXT_PUBLIC_STREAM_PROXY_TARGET=$NEXT_PUBLIC_STREAM_PROXY_TARGET
ENV NEXT_PUBLIC_SITE_NAME=$NEXT_PUBLIC_SITE_NAME
ENV NEXT_PUBLIC_AUDIO_DEBUG=$NEXT_PUBLIC_AUDIO_DEBUG
ENV NEXT_PUBLIC_APP_DEPLOYMENT_MODE=$NEXT_PUBLIC_APP_DEPLOYMENT_MODE

COPY . .

RUN pnpm --filter @web-radio/shared build
RUN pnpm --filter @web-radio/web build

FROM base AS runtime

ENV NODE_ENV=production
ARG BACKEND_PROXY_TARGET=http://localhost:3001
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_SOCKET_URL=
ARG NEXT_PUBLIC_MEDIA_BASE_URL=
ARG NEXT_PUBLIC_STREAM_URL=/live.mp3
ARG NEXT_PUBLIC_STREAM_PROXY_TARGET=http://icecast:8000
ARG NEXT_PUBLIC_SITE_NAME=PINE
ARG NEXT_PUBLIC_AUDIO_DEBUG=
ARG NEXT_PUBLIC_APP_DEPLOYMENT_MODE=hybrid
ENV BACKEND_PROXY_TARGET=$BACKEND_PROXY_TARGET
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SOCKET_URL=$NEXT_PUBLIC_SOCKET_URL
ENV NEXT_PUBLIC_MEDIA_BASE_URL=$NEXT_PUBLIC_MEDIA_BASE_URL
ENV NEXT_PUBLIC_STREAM_URL=$NEXT_PUBLIC_STREAM_URL
ENV NEXT_PUBLIC_STREAM_PROXY_TARGET=$NEXT_PUBLIC_STREAM_PROXY_TARGET
ENV NEXT_PUBLIC_SITE_NAME=$NEXT_PUBLIC_SITE_NAME
ENV NEXT_PUBLIC_AUDIO_DEBUG=$NEXT_PUBLIC_AUDIO_DEBUG
ENV NEXT_PUBLIC_APP_DEPLOYMENT_MODE=$NEXT_PUBLIC_APP_DEPLOYMENT_MODE

WORKDIR /app
COPY --from=build /app /app

WORKDIR /app/apps/web

EXPOSE 3000

CMD ["pnpm", "start", "-H", "0.0.0.0", "-p", "3000"]
