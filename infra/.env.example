# --- Ports ---
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
ICECAST_PORT=8000
API_PORT=3001
WEB_PORT=3000
NGINX_HTTP_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
BLACKBOX_PORT=9115
POSTGRES_EXPORTER_PORT=9187

# --- Database ---
POSTGRES_DB=pine
POSTGRES_USER=pine
POSTGRES_PASSWORD=replace_with_strong_postgres_password
DATABASE_URL=postgresql://pine:replace_with_strong_postgres_password@postgres:5432/pine?schema=public

# --- Auth / API ---
JWT_SECRET=replace_with_very_long_random_jwt_secret
JWT_REFRESH_SECRET=replace_with_very_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_STREAM_URL_TEMPLATE=/live.mp3
PLAYBACK_OUTBOX_POLL_INTERVAL_MS=400
PLAYBACK_OUTBOX_BATCH_SIZE=100

# --- MinIO ---
MINIO_ROOT_USER=pine
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_TRACKS=tracks
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_TRANSCODES=transcodes

# --- Icecast / Liquidsoap ---
ICECAST_SOURCE_PASSWORD=replace_with_strong_icecast_source_password
ICECAST_ADMIN_PASSWORD=replace_with_strong_icecast_admin_password
ICECAST_RELAY_PASSWORD=replace_with_strong_icecast_relay_password
ICECAST_HOSTNAME=
ICECAST_MOUNT=/live.mp3
ICECAST_PORT_INTERNAL=8000
ICECAST_HOST=icecast
ICECAST_PUBLIC_URL=/live.mp3
LIQUIDSOAP_SOURCE_NAME=PINE Radio
LIQUIDSOAP_CONTROL_DIR=/var/lib/liquidsoap/control
LIQUIDSOAP_CACHE_DIR=/var/lib/liquidsoap/cache
LIQUIDSOAP_TELNET_HOST=liquidsoap
LIQUIDSOAP_TELNET_PORT=1234

# --- Worker tuning ---
PLAYOUT_POLL_INTERVAL_MS=500
PLAYOUT_HEARTBEAT_INTERVAL_MS=30000
TRANSCODE_HEARTBEAT_INTERVAL_MS=30000

# --- Web ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost
NEXT_PUBLIC_SITE_NAME=PINE
NEXT_PUBLIC_STREAM_URL=/live.mp3

# --- Observability ---
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password
