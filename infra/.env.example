# --- Ports ---
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
API_PORT=3001
WEB_PORT=3000
NGINX_HTTP_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
BLACKBOX_PORT=9115
POSTGRES_EXPORTER_PORT=9187

# --- Database ---
POSTGRES_DB=pine
POSTGRES_USER=pine
POSTGRES_PASSWORD=replace_with_strong_postgres_password
DATABASE_URL=postgresql://pine:replace_with_strong_postgres_password@postgres:5432/pine?schema=public
REDIS_URL=redis://redis:6379

# --- Auth / API ---
JWT_SECRET=replace_with_very_long_random_jwt_secret
JWT_REFRESH_SECRET=replace_with_very_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_DEPLOYMENT_MODE=direct
PLAYBACK_OUTBOX_POLL_INTERVAL_MS=400
PLAYBACK_OUTBOX_BATCH_SIZE=100
PLAYBACK_OUTBOX_ADVISORY_LOCK_KEY=741337
MEDIA_DIRECT_URLS_ENABLED=1
MEDIA_DIRECT_REQUIRED=1
MEDIA_DIRECT_URL_TTL_SEC=900

# --- MinIO ---
MINIO_ROOT_USER=pine
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_TRACKS=tracks
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_TRANSCODES=transcodes

# --- Worker tuning ---
PLAYBACK_COMMAND_POLLING_ENABLED=0
PLAYBACK_POLL_INTERVAL_MS=500
PLAYBACK_HEARTBEAT_INTERVAL_MS=30000
PLAYBACK_RECONCILE_INTERVAL_MS=5000
PLAYBACK_STUCK_COMMAND_TTL_MS=60000
PLAYBACK_STUCK_COMMAND_RECOVERY_INTERVAL_MS=30000
MEDIA_POLL_INTERVAL_MS=1500
MEDIA_HEARTBEAT_INTERVAL_MS=30000
MEDIA_MAX_BATCH_PER_TICK=5
MEDIA_ENABLE_TRANSCODE=1
FFMPEG_BIN=ffmpeg
FFMPEG_TRANSCODE_TIMEOUT_MS=600000

# --- Web ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SITE_NAME=PINE
NEXT_PUBLIC_DIRECT_MEDIA_STRICT=1
BACKEND_PROXY_TARGET=http://api:3001
NEXT_PUBLIC_APP_DEPLOYMENT_MODE=direct

# --- Observability ---
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password
